#!/usr/bin/env bash
set -euo pipefail

if [[ -z "${QUIPU_SERVER_URL:-}" ]]; then
  echo "QUIPU_SERVER_URL is required" >&2
  exit 64
fi

if [[ -z "${QUIPU_AGENT_TOKEN:-}" ]]; then
  echo "QUIPU_AGENT_TOKEN is required" >&2
  exit 64
fi

collector_bin="${QUIPU_COLLECTOR_BIN:-/usr/local/bin/quipu-collector}"
collector_root="${QUIPU_COLLECTOR_ROOT:-/}"

args=(
  "--root" "${collector_root}"
  "--server-url" "${QUIPU_SERVER_URL}"
  "--token" "${QUIPU_AGENT_TOKEN}"
  "--once"
  "--offline-buffer"
  "--spool-dir" "${QUIPU_SPOOL_DIR:-/var/lib/quipu/collector-spool}"
  "--spool-max-batches" "${QUIPU_SPOOL_MAX_BATCHES:-288}"
  "--state-dir" "${QUIPU_STATE_DIR:-/var/lib/quipu/collector-state}"
)

if [[ -n "${QUIPU_COLLECTOR_DEVICE_ID:-}" ]]; then
  args+=("--device-id" "${QUIPU_COLLECTOR_DEVICE_ID}")
fi

if [[ -n "${QUIPU_COLLECTOR_DEVICE_ALIAS:-}" ]]; then
  args+=("--device-alias" "${QUIPU_COLLECTOR_DEVICE_ALIAS}")
fi

exec "${collector_bin}" "${args[@]}"
