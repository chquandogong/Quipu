# Quipu collector systemd environment.
#
# Copy this file to /etc/quipu/collector.env and set permissions so only root
# can read the token:
#
#   sudo install -D -m 0600 collector.env.example /etc/quipu/collector.env

QUIPU_SERVER_URL=http://127.0.0.1:8000
QUIPU_AGENT_TOKEN=replace-with-enrollment-token
QUIPU_COLLECTOR_ROOT=/

# Optional: override the generated device ID.
QUIPU_COLLECTOR_DEVICE_ID=

# Optional: friendly name shown beside the hostname in the Quipu UI.
QUIPU_COLLECTOR_DEVICE_ALIAS=

# Optional: override the collector binary path when installed outside
# /usr/local/bin.
QUIPU_COLLECTOR_BIN=/usr/local/bin/quipu-collector

# Optional: offline buffer settings. 288 five-minute batches is roughly one day.
QUIPU_SPOOL_DIR=/var/lib/quipu/collector-spool
QUIPU_SPOOL_MAX_BATCHES=288

# Optional: collector state used to calculate NVMe read/write bytes per second.
QUIPU_STATE_DIR=/var/lib/quipu/collector-state
